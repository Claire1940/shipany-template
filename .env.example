# app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="OneAIHub"
NEXT_PUBLIC_APP_DESCRIPTION="An all-in-one AI platform for chat, image generation, music generation, and creative AI tools."

# locale
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_LOCALE_DETECT_ENABLED="false"

# theme
NEXT_PUBLIC_THEME="trustai"

# appearance
NEXT_PUBLIC_APPEARANCE="dark"

# database
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:/root/Documents/AIProjects/shipany-template/data/local.db"
DB_SCHEMA_FILE="./src/config/db/schema.sqlite.ts"
DB_MIGRATIONS_OUT="./src/config/db/migrations_sqlite"
DB_SINGLETON_ENABLED="true"
DB_MAX_CONNECTIONS="1"

# auth secret
# openssl rand -base64 32
AUTH_SECRET=""